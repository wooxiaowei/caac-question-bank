{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".test-build",
    "noEmit": false,
    "rootDir": ".",
    "jsx": "react-jsx",
    "types": ["node"],
    "verbatimModuleSyntax": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/services/**/*.ts", "src/types.ts", "tests/**/*.ts"]
}
